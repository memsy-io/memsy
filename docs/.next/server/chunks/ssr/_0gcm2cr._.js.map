export let structuredData = {
  "contents": [{
    "heading": undefined,
    "content": "Memsy intentionally decouples ingestion from processing. This matters in a few places, so it's worth understanding the model."
  }, {
    "heading": "what-happens-when-you-call-ingest",
    "content": "The server:"
  }, {
    "heading": "what-happens-when-you-call-ingest",
    "content": "Validates the payload."
  }, {
    "heading": "what-happens-when-you-call-ingest",
    "content": "Writes the raw events to durable storage."
  }, {
    "heading": "what-happens-when-you-call-ingest",
    "content": "Returns a list of `event_ids`."
  }, {
    "heading": "what-happens-when-you-call-ingest",
    "content": "**Enqueues** the events for downstream processing (LLM extraction → embedding → indexing)."
  }, {
    "heading": "what-happens-when-you-call-ingest",
    "content": "Steps 1–3 happen synchronously over HTTP. Step 4 happens on the server's worker pool, after your call has already returned."
  }, {
    "heading": "why-its-designed-this-way",
    "content": "Applications in the hot path (chat loops, agent runtimes) log events without blocking on LLM latency."
  }, {
    "heading": "why-its-designed-this-way",
    "content": "Extraction can batch, retry, and prioritize without the client caring."
  }, {
    "heading": "why-its-designed-this-way",
    "content": "Costs and failures on the extraction side don't punish the caller."
  }, {
    "heading": "when-can-i-search-for-a-newly-ingested-event",
    "content": "Usually within a few seconds, but there's no guarantee. If your UX depends on memory being present immediately after ingest, poll for completion:"
  }, {
    "heading": "when-can-i-search-for-a-newly-ingested-event",
    "content": "`StatusResponse` partitions the IDs you sent into three buckets:"
  }, {
    "heading": "when-can-i-search-for-a-newly-ingested-event",
    "content": "`completed_ids` — extracted, embedded, indexed. Searchable now."
  }, {
    "heading": "when-can-i-search-for-a-newly-ingested-event",
    "content": "`pending_ids` — still in the queue or mid-processing."
  }, {
    "heading": "when-can-i-search-for-a-newly-ingested-event",
    "content": "`failed_ids` — something went wrong during extraction. These won't become memories."
  }, {
    "heading": "what-causes-an-event-to-fail",
    "content": "Content rejected by a content filter."
  }, {
    "heading": "what-causes-an-event-to-fail",
    "content": "An extraction-time LLM call that could not be recovered after retries."
  }, {
    "heading": "what-causes-an-event-to-fail",
    "content": "An event that referenced a deleted or quarantined resource."
  }, {
    "heading": "what-causes-an-event-to-fail",
    "content": "Failures are rare but not zero. Check `failed_ids` in your pollers if correctness matters."
  }, {
    "heading": "design-implications",
    "content": "**Don't block your request pipeline on `status()`.** Use it only when your next action requires the memory to be present."
  }, {
    "heading": "design-implications",
    "content": "**Don't re-ingest the same event to \"retry\".** Memsy de-duplicates ingestion by content hash within a short window; re-sending can create noise."
  }, {
    "heading": "design-implications",
    "content": "**Do batch aggressively.** `ingest()` accepts many events per call; fifty events in one batch is much cheaper than fifty single-event calls."
  }, {
    "heading": "next",
    "content": "How to build batches that ingest well → **Ingesting events**."
  }],
