export let structuredData = {
  "contents": [{
    "heading": undefined,
    "content": "`search()` takes a natural-language query and returns ranked memories."
  }, {
    "heading": "query",
    "content": "Plain English. You don't need to phrase it like a keyword search — \"things the user mentioned about their dog\" works."
  }, {
    "heading": "actor_id",
    "content": "Pass it to scope the search to one user/agent. Omit it to search across every actor in the organization. In most user-facing flows you want to pass the current actor."
  }, {
    "heading": "limit",
    "content": "How many results to return. Memsy may return fewer if not enough pass the threshold. Valid range: 1–100."
  }, {
    "heading": "threshold",
    "content": "A floor on the similarity score. The default `0.3` is a practical starting point — lower to get more results, raise to cut noise. A very high threshold (e.g. `0.8`) returns only near-exact matches."
  }, {
    "heading": "include_source_events",
    "content": "When `True`, each result additionally includes the source events the memory was extracted from. Useful for showing provenance in a UI."
  }, {
    "heading": "reading-usage-and-rate-limit-info",
    "content": "Every response carries observability metadata:"
  }, {
    "heading": "reading-usage-and-rate-limit-info",
    "content": "See **Usage and Rate Limits** for every field."
  }, {
    "heading": "cross-actor-search-admin-tools",
    "content": "Leave `actor_id` unset and you'll search every actor in the org. Good for analytics dashboards and support tooling; almost never what you want in an end-user-facing agent loop."
  }, {
    "heading": "empty-results",
    "content": "`search()` always returns a `SearchResponse`. If nothing passed the threshold, `results.results == []`. Handle that case in your UI."
  }, {
    "heading": "limitations",
    "content": "Scores are not comparable across queries — `0.6` for query A is not the same thing as `0.6` for query B. Use `threshold` relative to the domain, not as an absolute quality bar."
  }, {
    "heading": "limitations",
    "content": "Search only returns memories that have finished processing. Very recent events may still be in the queue — see **Async Processing**."
  }, {
    "heading": "next",
    "content": "Run the same thing from asyncio → **Async client**."
  }],
  "headings": [{
