export let structuredData = {
  "contents": [{
    "heading": undefined,
    "content": "Memsy supports a three-level onboarding hierarchy — **org → role → team** — that controls how memories are scoped and how extraction prompts are customised. Setting this up is optional: the SDK works fine without it, but adding hierarchy lets you tune extraction for different parts of your user base."
  }, {
    "heading": "hierarchy-overview",
    "content": "Roles and teams are **independent siblings** under an org — a role does not belong to a team in the data model. An actor can be tagged with both a `role_id` and a `team_id` at the same time."
  }, {
    "heading": "hierarchy-overview",
    "content": "What connects them is the **memory promotion chain**: when memories are promoted up the hierarchy, the path is actor → role → team → org. Each level has its own `promotion_prompt` that biases extraction for what matters at that scope."
  }, {
    "heading": "hierarchy-overview",
    "content": "Events tagged with `role_id` or `team_id` in `EventPayload` are extracted with the customised prompt for that role/team."
  }, {
    "heading": "accessing-the-sub-resources",
    "content": "Async equivalents are available on `AsyncMemsyClient` — same methods, all `await`ed."
  }, {
    "heading": "regenerate-prompt",
    "content": "Re-runs the LLM prompt generation using the current `name` and `focus`:"
  }, {
    "heading": "roles",
    "content": "Roles represent distinct personas or job functions within your org."
  }, {
    "heading": "teams",
    "content": "Teams represent groups of actors that share a context."
  }, {
    "heading": "tagging-events-with-roleteam",
    "content": "Once the hierarchy is set up, tag events at ingest time:"
  }, {
    "heading": "tagging-events-with-roleteam",
    "content": "The memory extractor uses the role's/team's `promotion_prompt` to bias extraction toward relevant facts for that context."
  }, {
    "heading": "response-model",
    "content": "All three sub-resources return their respective models:"
  }, {
    "heading": "response-model",
    "content": "See **Models** for the full `OrgResource`, `RoleResource`, and `TeamResource` definitions."
  }, {
    "heading": "see-also",
    "content": "**Ingesting Events** — `role_id` / `team_id` on `EventPayload`."
  }, {
    "heading": "see-also",
    "content": "**Console Memories** — browse memories scoped to roles/teams."
  }, {
