{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${PLUGIN_ROOT}\"/hooks/session-start.sh",
            "statusMessage": "Memsy session context"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${PLUGIN_ROOT}\"/hooks/user-prompt-submit.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${PLUGIN_ROOT}\"/hooks/stop.sh",
            "statusMessage": "Memsy turn sync (when enabled)",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
