{
  "name": "@memsy-io/memsy",
  "version": "0.1.2",
  "description": "Official Node.js SDK for the Memsy memory service",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "memsy",
    "memory",
    "ai",
    "sdk",
    "llm",
    "memory-layer"
  ],
  "author": "memsy <gaurav@memsy.io>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/memsy-io/memsy",
    "directory": "sdks/node"
  },
  "dependencies": {},
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
